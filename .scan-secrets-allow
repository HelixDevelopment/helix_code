# scan-secrets allowlist — paths/files where token-shape patterns are intentional
# documentation, test fixtures, planted-secret examples for the scanner test harness, etc.
# Format: one path glob per line. # for comments.
# Basename globs work (e.g. *.md matches any .md file). Full path globs also work.

# .env files: these are gitignored by design and hold real credentials locally.
# They must NEVER be committed; the scanner correctly skips them here because
# they are already covered by .gitignore. The pre-push hook gates committed content,
# not the local working tree .env files.
.env
.env.*
HelixCode/.env
HelixCode/.env.*

# Documentation files with example keys/tokens (not real secrets)
docs/COMPLETE_CLI_REFERENCE.md
docs/troubleshooting/guide.md
docs/superpowers/plans/*.md
docs/superpowers/specs/*.md
docs/improvements/05_phase_0_evidence.md

# HelixCode test files — contain fake/example API keys and JWTs as test fixtures
HelixCode/internal/llm/*_test.go
HelixCode/internal/worker/*_test.go
HelixCode/tests/e2e/test-bank/*_test.go
HelixCode/tests/e2e/test-bank/performance_security_tests.go
HelixCode/tests/security/authentication_test.go
HelixCode/tests/security/authorization_test.go

# HelixCode API spec — JWT examples in OpenAPI documentation (not real tokens)
HelixCode/api/openapi.yaml

# Challenges test/security files with example patterns
Challenges/Panoptic/tests/security/*_test.go
Challenges/pkg/env/redact_test.go
Challenges/pkg/logging/redacting_logger_test.go
Challenges/Panoptic/docs/SECURITY.md

# HelixQA test files — contain fake API keys for unit test validation
HelixQA/pkg/llm/google_test.go

# Security package test files — contain PEM stubs/examples for unit tests
Security/pkg/securestorage/securestorage_test.go

# Example_Resources — third-party cookbook/examples directory, not production code
Example_Resources/*

# SSH key test fixtures (ephemeral, gitignored, not committed) — old keys on disk
HelixCode/test/workers/ssh-keys/id_rsa

# External/vendor package-lock files (integrity hashes, not secrets)
**/package-lock.json
package-lock.json

# Scanner infrastructure — this script and its test contain planted secrets intentionally
scripts/scan-secrets.sh
scripts/test-scan-secrets.sh
.scan-secrets-allow
