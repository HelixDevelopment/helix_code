{
  "challenge": "snyk-scanning-config",
  "description": "Validates Snyk security scanning infrastructure configuration for HelixCode",
  "note": "Configuration-only challenge. Live scans require SNYK_TOKEN to be rotated first (see P0-T08.5 remediation notes).",
  "must_appear": [
    "PASS.*Snyk docker-compose\\.yml exists",
    "PASS.*Snyk Dockerfile exists",
    "PASS.*Root \\.snyk policy file exists",
    "PASS.*SNYK_TOKEN uses env-var reference",
    "PASS.*No HelixAgent-specific container names",
    "PASS.*snyk-deps service defined",
    "PASS.*snyk-code service defined",
    "PASS.*snyk-full service defined",
    "PASS.*Snyk containers have 2g memory limit",
    "PASS.*Dockerfile uses official snyk/snyk-cli base image",
    "PASS.*\\.snyk has policy version",
    "PASS.*security-scan\\.sh --help shows snyk mode",
    "PASS.*cmd/security_scan imports Containers BootManager",
    "PASS.*cmd/security_scan handles snyk scanner"
  ],
  "must_not_appear": [
    "FAIL.*SNYK_TOKEN uses env-var",
    "FAIL.*No HelixAgent-specific",
    "FAIL.*snyk-deps service defined",
    "FAIL.*Dockerfile uses official snyk",
    "FAIL.*cmd/security_scan imports Containers",
    "helixagent",
    "hardcoded",
    "TODO.*implement"
  ]
}
