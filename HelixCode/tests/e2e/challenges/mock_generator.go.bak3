// GenerateURLShortener generates a mock URL Shortener service
func (g *MockGenerator) GenerateURLShortener(ctx context.Context, outputDir string) error {
	// Create directory structure
	dirs := []string{
		filepath.Join(outputDir, "internal", "api"),
		filepath.Join(outputDir, "internal", "storage"),
		filepath.Join(outputDir, "internal", "models"),
		filepath.Join(outputDir, "tests"),
	}

	for _, dir := range dirs {
		if err := os.MkdirAll(dir, 0755); err != nil {
			return fmt.Errorf("failed to create directory %s: %w", dir, err)
		}
	}

	// Create go.mod
	goMod := `module url-shortener

go 1.24

require (
	github.com/gin-gonic/gin v1.9.1
	github.com/google/uuid v1.6.0
	github.com/boltdb/bolt v1.3.7
)

require (
	github.com/bytedance/sonic v1.9.1 // indirect
	github.com/chenzhuoyu/base64x v0.0.0-20221115062448-fe3a3abad311 // indirect
	github.com/gabriel-vasile/mimetype v1.4.2 // indirect
	github.com/gin-contrib/sse v0.1.0 // indirect
	github.com/go-playground/locales v0.14.1 // indirect
	github.com/go-playground/universal-translator v0.18.1 // indirect
	github.com/go-playground/validator/v10 v10.14.0 // indirect
	github.com/goccy/go-json v0.10.2 // indirect
	github.com/json-iterator/go v1.1.12 // indirect
	github.com/klauspost/cpuid/v2 v2.2.4 // indirect
	github.com/leodido/go-urn v1.2.4 // indirect
	github.com/mattn/go-isatty v0.0.19 // indirect
	github.com/modern-go/concurrent v0.0.0-20180306012644-bacd9c7ef1dd // indirect
	github.com/modern-go/reflect2 v1.0.2 // indirect
	github.com/pelletier/go-toml/v2 v2.0.8 // indirect
	github.com/twitchyliquid64/golang-asm v0.15.1 // indirect
	github.com/ugorji/go/codec v1.2.11 // indirect
	golang.org/x/arch v0.3.0 // indirect
	golang.org/x/crypto v0.9.0 // indirect
	golang.org/x/net v0.10.0 // indirect
	golang.org/x/sys v0.8.0 // indirect
	golang.org/x/text v0.9.0 // indirect
	google.golang.org/protobuf v1.30.0 // indirect
	gopkg.in/yaml.v3 v3.0.1 // indirect
)
`
	if err := os.WriteFile(filepath.Join(outputDir, "go.mod"), []byte(goMod), 0644); err != nil {
		return err
	}

	// Create main.go
	mainGo := `package main

import (
	"log"
	"url-shortener/internal/api"
	"url-shortener/internal/storage"

	"github.com/gin-gonic/gin"
)

func main() {
	// Initialize storage
	store, err := storage.NewStorage("shortener.db")
	if err != nil {
		log.Fatalf("Failed to initialize storage: %v", err)
	}
	defer store.Close()

	// Initialize API handler
	handler := api.NewHandler(store)

	// Setup router
	router := gin.Default()

	// API routes
	apiGroup := router.Group("/api/v1")
	{
		apiGroup.POST("/shorten", handler.CreateShortURL)
		apiGroup.GET("/:short", handler.RedirectURL)
		apiGroup.GET("/info/:short", handler.GetURLInfo)
		apiGroup.DELETE("/:short", handler.DeleteURL)
	}

	// Health check
	router.GET("/health", handler.HealthCheck)

	// Start server
	log.Println("URL Shortener starting on :8080")
	if err := router.Run(":8080"); err != nil {
		log.Fatalf("Failed to start server: %v", err)
	}
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "main.go"), []byte(mainGo), 0644); err != nil {
		return err
	}

	// Create internal/models/url.go
	modelsGo := `package models

import (
	"time"

	"github.com/google/uuid"
)

type URL struct {
	ID           string    ` + "`json:\"id\"`" + `
	ShortCode    string    ` + "`json:\"short_code\"`" + `
	OriginalURL  string    ` + "`json:\"original_url\"`" + `
	CreatedAt    time.Time ` + "`json:\"created_at\"`" + `
	ExpiresAt    *time.Time ` + "`json:\"expires_at,omitempty\"`" + `
	ClickCount   int       ` + "`json:\"click_count\"`" + `
	LastAccessed *time.Time ` + "`json:\"last_accessed,omitempty\"`" + `
	CustomAlias  string    ` + "`json:\"custom_alias,omitempty\"`" + `
	Password     string    ` + "`json:\"password,omitempty\"`" + `
	IsActive     bool      ` + "`json:\"is_active\"`" + `
}

type CreateURLRequest struct {
	URL        string ` + "`json:\"url\" binding:\"required\"`" + `
	CustomAlias string ` + "`json:\"custom_alias,omitempty\"`" + `
	Password   string ` + "`json:\"password,omitempty\"`" + `
	ExpiresIn  string ` + "`json:\"expires_in,omitempty\"`" + ` // e.g., "1h", "7d", "30d"
}

type URLResponse struct {
	ShortURL    string ` + "`json:\"short_url\"`" + `
	ShortCode   string ` + "`json:\"short_code\"`" + `
	OriginalURL string ` + "`json:\"original_url\"`" + `
}

type URLInfoResponse struct {
	URL           string ` + "`json:\"url\"`" + `
	ShortCode     string ` + "`json:\"short_code\"`" + `
	CreatedAt     string ` + "`json:\"created_at\"`" + `
	ClickCount    int    ` + "`json:\"click_count\"`" + `
	LastAccessed  string ` + "`json:\"last_accessed,omitempty\"`" + `
	ExpiresAt     string ` + "`json:\"expires_at,omitempty\"`" + `
}

func NewURL(originalURL, customAlias string) *URL {
	return &URL{
		ID:          uuid.New().String(),
		OriginalURL:  originalURL,
		ShortCode:    generateShortCode(),
		CustomAlias:  customAlias,
		CreatedAt:    time.Now(),
		ClickCount:   0,
		IsActive:     true,
	}
}

func generateShortCode() string {
	// Simple implementation - in production use a more sophisticated method
	return uuid.New().String()[:8]
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "internal", "models", "url.go"), []byte(modelsGo), 0644); err != nil {
		return err
	}

	// Create internal/storage/bolt.go
	storageGo := `package storage

import (
	"encoding/json"
	"fmt"
	"time"

	"url-shortener/internal/models"

	"github.com/boltdb/bolt"
)

type Storage interface {
	CreateURL(url *models.URL) error
	GetURL(shortCode string) (*models.URL, error)
	GetURLByAlias(alias string) (*models.URL, error)
	UpdateURL(url *models.URL) error
	DeleteURL(shortCode string) error
	IncrementClickCount(shortCode string) error
	GetURLStats() (map[string]interface{}, error)
	Close() error
}

type BoltStorage struct {
	db *bolt.DB
}

func NewStorage(path string) (*BoltStorage, error) {
	db, err := bolt.Open(path, 0600, &bolt.Options{Timeout: 1 * time.Second})
	if err != nil {
		return nil, fmt.Errorf("failed to open database: %w", err)
	}

	err = db.Update(func(tx *bolt.Tx) error {
		_, err := tx.CreateBucketIfNotExists([]byte("urls"))
		if err != nil {
			return fmt.Errorf("create bucket: %s", err)
		}
		_, err = tx.CreateBucketIfNotExists([]byte("stats"))
		if err != nil {
			return fmt.Errorf("create stats bucket: %s", err)
		}
		return nil
	})
	if err != nil {
		return nil, fmt.Errorf("create bucket: %s", err)
	}

	return &BoltStorage{db: db}, nil
}

func (s *BoltStorage) CreateURL(url *models.URL) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		data, err := json.Marshal(url)
		if err != nil {
			return err
		}
		return b.Put([]byte(url.ShortCode), data)
	})
}

func (s *BoltStorage) GetURL(shortCode string) (*models.URL, error) {
	var url models.URL
	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		data := b.Get([]byte(shortCode))
		if data == nil {
			return fmt.Errorf("URL not found")
		}
		return json.Unmarshal(data, &url)
	})
	if err != nil {
		return nil, err
	}
	return &url, nil
}

func (s *BoltStorage) GetURLByAlias(alias string) (*models.URL, error) {
	var url models.URL
	var found bool
	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		return b.ForEach(func(k, v []byte) error {
			var u models.URL
			if err := json.Unmarshal(v, &u); err != nil {
				return err
			}
			if u.CustomAlias == alias && u.IsActive {
				url = u
				found = true
			}
			return nil
		})
	})
	if err != nil {
		return nil, err
	}
	if !found {
		return nil, fmt.Errorf("URL not found")
	}
	return &url, nil
}

func (s *BoltStorage) UpdateURL(url *models.URL) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		data, err := json.Marshal(url)
		if err != nil {
			return err
		}
		return b.Put([]byte(url.ShortCode), data)
	})
}

func (s *BoltStorage) DeleteURL(shortCode string) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		return b.Delete([]byte(shortCode))
	})
}

func (s *BoltStorage) IncrementClickCount(shortCode string) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		data := b.Get([]byte(shortCode))
		if data == nil {
			return fmt.Errorf("URL not found")
		}

		var url models.URL
		if err := json.Unmarshal(data, &url); err != nil {
			return err
		}

		url.ClickCount++
		now := time.Now()
		url.LastAccessed = &now

		updatedData, err := json.Marshal(url)
		if err != nil {
			return err
		}

		return b.Put([]byte(shortCode), updatedData)
	})
}

func (s *BoltStorage) GetURLStats() (map[string]interface{}, error) {
	stats := make(map[string]interface{})
	var totalURLs, totalClicks int

	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("urls"))
		return b.ForEach(func(k, v []byte) error {
			var url models.URL
			if err := json.Unmarshal(v, &url); err != nil {
				return err
			}
			if url.IsActive {
				totalURLs++
				totalClicks += url.ClickCount
			}
			return nil
		})
	})

	if err != nil {
		return nil, err
	}

	stats["total_urls"] = totalURLs
	stats["total_clicks"] = totalClicks
	return stats, nil
}

func (s *BoltStorage) Close() error {
	return s.db.Close()
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "internal", "storage", "bolt.go"), []byte(storageGo), 0644); err != nil {
