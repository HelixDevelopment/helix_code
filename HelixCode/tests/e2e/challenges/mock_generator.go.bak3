	}

	// Create internal/api/handler.go
	apiGo := `package api

import (
	"net/http"
	"time"
	"url-shortener/internal/models"
	"url-shortener/internal/storage"

	"github.com/gin-gonic/gin"
)

type Handler struct {
	storage storage.Storage
}

func NewHandler(s storage.Storage) *Handler {
	return &Handler{storage: s}
}

// CreateShortURL creates a shortened URL
func (h *Handler) CreateShortURL(c *gin.Context) {
	var req models.CreateURLRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	// Check if custom alias is already taken
	if req.CustomAlias != "" {
		existing, err := h.storage.GetURLByAlias(req.CustomAlias)
		if err == nil && existing.IsActive {
			c.JSON(http.StatusConflict, gin.H{"error": "Custom alias already taken"})
			return
		}
	}

	// Create new URL
	url := models.NewURL(req.URL, req.CustomAlias)
	if req.Password != "" {
		url.Password = req.Password
	}

	// Parse expiration
	if req.ExpiresIn != "" {
		duration, err := time.ParseDuration(req.ExpiresIn)
		if err != nil {
			c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid expiration duration"})
			return
		}
		expiresAt := time.Now().Add(duration)
		url.ExpiresAt = &expiresAt
	}

	if err := h.storage.CreateURL(url); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to create URL"})
		return
	}

	response := models.URLResponse{
		ShortURL:    buildShortURL(c, url.ShortCode),
		ShortCode:   url.ShortCode,
		OriginalURL: url.OriginalURL,
	}

	c.JSON(http.StatusCreated, response)
}

// RedirectURL redirects to the original URL
func (h *Handler) RedirectURL(c *gin.Context) {
	shortCode := c.Param("short")

	// Try to get by short code first
	url, err := h.storage.GetURL(shortCode)
	if err != nil {
		// Try custom alias
		url, err = h.storage.GetURLByAlias(shortCode)
		if err != nil {
			c.JSON(http.StatusNotFound, gin.H{"error": "URL not found"})
			return
		}
	}

	// Check if URL is active and not expired
	if !url.IsActive {
		c.JSON(http.StatusGone, gin.H{"error": "URL is no longer active"})
		return
	}

	if url.ExpiresAt != nil && time.Now().After(*url.ExpiresAt) {
		c.JSON(http.StatusGone, gin.H{"error": "URL has expired"})
		return
	}

	// Check password protection
	if url.Password != "" {
		password := c.Query("password")
		if password != url.Password {
			c.JSON(http.StatusUnauthorized, gin.H{"error": "Password required"})
			return
		}
	}

	// Increment click count
	h.storage.IncrementClickCount(shortCode)

	// Redirect to original URL
	c.Redirect(http.StatusMovedPermanently, url.OriginalURL)
}

// GetURLInfo returns information about a shortened URL
func (h *Handler) GetURLInfo(c *gin.Context) {
	shortCode := c.Param("short")

	url, err := h.storage.GetURL(shortCode)
	if err != nil {
		url, err = h.storage.GetURLByAlias(shortCode)
		if err != nil {
			c.JSON(http.StatusNotFound, gin.H{"error": "URL not found"})
			return
		}
	}

	response := models.URLInfoResponse{
		URL:        url.OriginalURL,
		ShortCode:  url.ShortCode,
		CreatedAt:  url.CreatedAt.Format(time.RFC3339),
		ClickCount: url.ClickCount,
	}

	if url.LastAccessed != nil {
		response.LastAccessed = url.LastAccessed.Format(time.RFC3339)
	}

	if url.ExpiresAt != nil {
		response.ExpiresAt = url.ExpiresAt.Format(time.RFC3339)
	}

	c.JSON(http.StatusOK, response)
}

// DeleteURL deletes a shortened URL
func (h *Handler) DeleteURL(c *gin.Context) {
	shortCode := c.Param("short")

	_, err := h.storage.GetURL(shortCode)
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "URL not found"})
		return
	}

	if err := h.storage.DeleteURL(shortCode); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to delete URL"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "URL deleted successfully"})
}

// HealthCheck returns service health
func (h *Handler) HealthCheck(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{
		"status":    "healthy",
		"service":   "url-shortener",
		"version":   "1.0.0",
		"timestamp": time.Now().Format(time.RFC3339),
	})
}

func buildShortURL(c *gin.Context, shortCode string) string {
	scheme := "http"
	if c.GetHeader("X-Forwarded-Proto") == "https" || c.Request.TLS != nil {
		scheme = "https"
	}
	return scheme + "://" + c.Request.Host + "/" + shortCode
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "internal", "api", "handler.go"), []byte(apiGo), 0644); err != nil {
		return err
	}

	// Create tests/api_test.go
	testGo := `package tests

import (
	"bytes"
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"url-shortener/internal/api"
	"url-shortener/internal/models"
	"url-shortener/internal/storage"
	"testing"

	"github.com/gin-gonic/gin"
	"github.com/stretchr/testify/assert"
)

func setupTestRouter() (*gin.Engine, storage.Storage) {
	// Use test mode
gin.SetMode(gin.TestMode)

	// Create in-memory storage
	store, _ := storage.NewStorage(":memory:")
	handler := api.NewHandler(store)

	router := gin.Default()
	apiGroup := router.Group("/api/v1")
	{
		apiGroup.POST("/shorten", handler.CreateShortURL)
		apiGroup.GET("/:short", handler.RedirectURL)
		apiGroup.GET("/info/:short", handler.GetURLInfo)
		apiGroup.DELETE("/:short", handler.DeleteURL)
	}
	router.GET("/health", handler.HealthCheck)

	return router, store
}

func TestCreateShortURL(t *testing.T) {
	router, _ := setupTestRouter()

	reqBody := models.CreateURLRequest{
		URL:        "https://example.com",
		CustomAlias: "test",
	}

	jsonData, _ := json.Marshal(reqBody)
	req, _ := http.NewRequest("POST", "/api/v1/shorten", bytes.NewBuffer(jsonData))
	req.Header.Set("Content-Type", "application/json")

	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	assert.Equal(t, http.StatusCreated, w.Code)

	var response models.URLResponse
	_ = json.Unmarshal(w.Body.Bytes(), &response)

	assert.Equal(t, "https://example.com", response.OriginalURL)
	assert.NotEmpty(t, response.ShortURL)
}

func TestRedirectURL(t *testing.T) {
	router, store := setupTestRouter()

	// First create a URL
	url := models.NewURL("https://example.com", "")
	_ = store.CreateURL(url)

	// Then test redirect
	req, _ := http.NewRequest("GET", "/"+url.ShortCode, nil)
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	assert.Equal(t, http.StatusMovedPermanently, w.Code)
	assert.Equal(t, "https://example.com", w.Header().Get("Location"))
}

func TestGetURLInfo(t *testing.T) {
	router, store := setupTestRouter()

	// Create a URL
	url := models.NewURL("https://example.com", "")
	_ = store.CreateURL(url)

	req, _ := http.NewRequest("GET", "/api/v1/info/"+url.ShortCode, nil)
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	assert.Equal(t, http.StatusOK, w.Code)

	var response models.URLInfoResponse
	_ = json.Unmarshal(w.Body.Bytes(), &response)

	assert.Equal(t, "https://example.com", response.URL)
	assert.Equal(t, url.ShortCode, response.ShortCode)
	assert.Equal(t, 0, response.ClickCount)
}

func TestHealthCheck(t *testing.T) {
	router, _ := setupTestRouter()

	req, _ := http.NewRequest("GET", "/health", nil)
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	assert.Equal(t, http.StatusOK, w.Code)

	var response map[string]interface{}
	_ = json.Unmarshal(w.Body.Bytes(), &response)

	assert.Equal(t, "healthy", response["status"])
}
`
