// GenerateCLITaskManager generates a mock CLI Task Manager tool
func (g *MockGenerator) GenerateCLITaskManager(ctx context.Context, outputDir string) error {
	// Create directory structure
	dirs := []string{
		filepath.Join(outputDir, "task"),
		filepath.Join(outputDir, "storage"),
		filepath.Join(outputDir, "tests"),
	}

	for _, dir := range dirs {
		if err := os.MkdirAll(dir, 0755); err != nil {
			return fmt.Errorf("failed to create directory %s: %w", dir, err)
		}
	}

	// Create go.mod
	goMod := `module cli-task-manager

go 1.24

require (
	github.com/spf13/cobra v1.8.0
	github.com/boltdb/bolt v1.3.7
)

require (
	github.com/inconshreveable/mousetrap v1.1.0 // indirect
	github.com/spf13/pflag v1.0.5 // indirect
)
`
	if err := os.WriteFile(filepath.Join(outputDir, "go.mod"), []byte(goMod), 0644); err != nil {
		return err
	}

	// Create main.go
	mainGo := `package main

import (
	"fmt"
	"cli-task-manager/task"
	"cli-task-manager/storage"

	"github.com/spf13/cobra"
)

func main() {
	// Initialize storage
	store, err := storage.NewStorage("tasks.db")
	if err != nil {
		fmt.Fprintf(os.Stderr, "Failed to initialize storage: %v\n", err)
		os.Exit(1)
	}
	defer store.Close()

	// Create task manager
	tm := task.NewManager(store)

	var rootCmd = &cobra.Command{
		Use:   "task-manager",
		Short: "A CLI task management tool",
		Long: ` + "`" + `Task Manager CLI

A powerful command-line task management tool with support for:
- Task creation, listing, updating, and deletion
- Priority levels and status tracking
- Project organization
- Search and filtering
- Data persistence` + "`" + `,
	}

	// Add subcommands
	rootCmd.AddCommand(task.NewAddCmd(tm))
	rootCmd.AddCommand(task.NewListCmd(tm))
	rootCmd.AddCommand(task.NewUpdateCmd(tm))
	rootCmd.AddCommand(task.NewDeleteCmd(tm))
	rootCmd.AddCommand(task.NewSearchCmd(tm))
	rootCmd.AddCommand(task.NewCompleteCmd(tm))

	if err := rootCmd.Execute(); err != nil {
		fmt.Fprintf(os.Stderr, "Error: %v\n", err)
		os.Exit(1)
	}
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "main.go"), []byte(mainGo), 0644); err != nil {
		return err
	}

	// Create storage/bolt.go
	storageGo := `package storage

import (
	"encoding/json"
	"fmt"
	"time"

	"github.com/boltdb/bolt"
)

// Storage interface defines storage operations
type Storage interface {
	AddTask(task *Task) error
	GetTask(id string) (*Task, error)
	ListTasks() ([]*Task, error)
	UpdateTask(id string, task *Task) error
	DeleteTask(id string) error
	SearchTasks(query string) ([]*Task, error)
	Close() error
}

// Task represents a task
type Task struct {
	ID          string    ` + "`json:\"id\"`" + `
	Title       string    ` + "`json:\"title\"`" + `
	Description string    ` + "`json:\"description\"`" + `
	Status      string    ` + "`json:\"status\"`" + ` // pending, in-progress, completed
	Priority    string    ` + "`json:\"priority\"`" + ` // low, medium, high
	Project     string    ` + "`json:\"project\"`" + `
	CreatedAt   time.Time ` + "`json:\"created_at\"`" + `
	UpdatedAt   time.Time ` + "`json:\"updated_at\"`" + `
	DueDate     *time.Time ` + "`json:\"due_date,omitempty\"`" + `
}

// BoltStorage implements Storage using BoltDB
type BoltStorage struct {
	db *bolt.DB
}

// NewStorage creates a new BoltDB storage
func NewStorage(path string) (*BoltStorage, error) {
	db, err := bolt.Open(path, 0600, &bolt.Options{Timeout: 1 * time.Second})
	if err != nil {
		return nil, fmt.Errorf("failed to open database: %w", err)
	}

	err = db.Update(func(tx *bolt.Tx) error {
		_, err := tx.CreateBucketIfNotExists([]byte("tasks"))
		return err
	})
	if err != nil {
		return nil, fmt.Errorf("failed to create bucket: %w", err)
	}

	return &BoltStorage{db: db}, nil
}

// AddTask adds a new task
func (s *BoltStorage) AddTask(task *Task) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		data, err := json.Marshal(task)
		if err != nil {
			return err
		}
		return b.Put([]byte(task.ID), data)
	})
}

// GetTask retrieves a task by ID
func (s *BoltStorage) GetTask(id string) (*Task, error) {
	var task Task
	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		data := b.Get([]byte(id))
		if data == nil {
			return fmt.Errorf("task not found")
		}
		return json.Unmarshal(data, &task)
	})
	if err != nil {
		return nil, err
	}
	return &task, nil
}

// ListTasks returns all tasks
func (s *BoltStorage) ListTasks() ([]*Task, error) {
	var tasks []*Task
	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		return b.ForEach(func(k, v []byte) error {
			var task Task
			if err := json.Unmarshal(v, &task); err != nil {
				return err
			}
			tasks = append(tasks, &task)
			return nil
		})
	})
	return tasks, err
}

// UpdateTask updates an existing task
func (s *BoltStorage) UpdateTask(id string, task *Task) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		data, err := json.Marshal(task)
		if err != nil {
			return err
		}
		return b.Put([]byte(id), data)
	})
}

// DeleteTask deletes a task
func (s *BoltStorage) DeleteTask(id string) error {
	return s.db.Update(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		return b.Delete([]byte(id))
	})
}

// SearchTasks searches tasks by title/description
func (s *BoltStorage) SearchTasks(query string) ([]*Task, error) {
	var tasks []*Task
	err := s.db.View(func(tx *bolt.Tx) error {
		b := tx.Bucket([]byte("tasks"))
		return b.ForEach(func(k, v []byte) error {
			var task Task
			if err := json.Unmarshal(v, &task); err != nil {
				return err
			}
			// Simple search - in production use full-text search
			if contains(task.Title, query) || contains(task.Description, query) {
				tasks = append(tasks, &task)
			}
			return nil
		})
	})
	return tasks, err
}

// Close closes the database
func (s *BoltStorage) Close() error {
	return s.db.Close()
}

// Helper function for simple string contains
type Contains interface {
	Contains(string) bool
}

func contains(s, substr string) bool {
	return len(s) >= len(substr) && (s == substr || len(s) > 0 && (s[:len(substr)] == substr || s[len(s)-len(substr):] == substr || containsSubstring(s, substr)))
}

func containsSubstring(s, substr string) bool {
	for i := 0; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "storage", "bolt.go"), []byte(storageGo), 0644); err != nil {
		return err
	}

	// Create task/commands.go
	commandsGo := `package task

import (
	"fmt"
	"os"
	"strings"
	"time"

	"cli-task-manager/storage"

	"github.com/spf13/cobra"
	"github.com/google/uuid"
)

type Manager struct {
	storage storage.Storage
}

func NewManager(s storage.Storage) *Manager {
	return &Manager{storage: s}
}

// Add command
func NewAddCmd(tm *Manager) *cobra.Command {
	var priority, project, dueDate, description string

	cmd := &cobra.Command{
		Use:   "add [title]",
		Short: "Add a new task",
		Long: "Create a new task with optional priority, project, and due date",
		Args: cobra.MinimumNArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			title := strings.Join(args, " ")
			
			// Set defaults
			if priority == "" {
				priority = "medium"
			}
			if project == "" {
				project = "default"
			}

			task := &storage.Task{
				ID:          uuid.New().String(),
				Title:       title,
				Description: description,
				Status:      "pending",
				Priority:    priority,
				Project:     project,
				CreatedAt:   time.Now(),
				UpdatedAt:   time.Now(),
			}

			if dueDate != "" {
				parsed, err := time.Parse("2006-01-02", dueDate)
				if err != nil {
					fmt.Fprintf(os.Stderr, "Invalid due date format: %v\n", err)
					return
				}
				task.DueDate = &parsed
			}

			if err := tm.storage.AddTask(task); err != nil {
				fmt.Fprintf(os.Stderr, "Failed to add task: %v\n", err)
				return
			}

			fmt.Printf("✓ Added task: %s\n", task.Title)
		},
	}

	cmd.Flags().StringVar(&priority, "priority", "", "Task priority (low, medium, high)")
	cmd.Flags().StringVar(&project, "project", "", "Project name")
	cmd.Flags().StringVar(&dueDate, "due", "", "Due date (YYYY-MM-DD)")
	cmd.Flags().StringVar(&description, "desc", "", "Task description")

	return cmd
}

// List command
func NewListCmd(tm *Manager) *cobra.Command {
	var status, priority, project string

	cmd := &cobra.Command{
		Use:   "list",
		Short: "List tasks",
		Long: "Display tasks with optional filtering by status, priority, or project",
		Run: func(cmd *cobra.Command, args []string) {
			tasks, err := tm.storage.ListTasks()
			if err != nil {
				fmt.Fprintf(os.Stderr, "Failed to list tasks: %v\n", err)
				return
			}

			// Apply filters
			var filtered []*storage.Task
			for _, task := range tasks {
				if status != "" && task.Status != status {
					continue
				}
				if priority != "" && task.Priority != priority {
					continue
				}
				if project != "" && task.Project != project {
					continue
				}
				filtered = append(filtered, task)
			}

			if len(filtered) == 0 {
				fmt.Println("No tasks found")
				return
			}

			// Display tasks
			for _, task := range filtered {
				statusIcon := getStatusIcon(task.Status)
				priorityIcon := getPriorityIcon(task.Priority)
				
				fmt.Printf("%s %s - %s [%s] (%s)\n", statusIcon, priorityIcon, task.Title, task.Project, task.Priority)
				if task.Description != "" {
					fmt.Printf("   %s\n", task.Description)
				}
				if task.DueDate != nil {
					fmt.Printf("   Due: %s\n", task.DueDate.Format("2006-01-02"))
				}
				fmt.Printf("   ID: %s\n\n", task.ID)
			}
		},
	}

	cmd.Flags().StringVar(&status, "status", "", "Filter by status (pending, in-progress, completed)")
	cmd.Flags().StringVar(&priority, "priority", "", "Filter by priority (low, medium, high)")
	cmd.Flags().StringVar(&project, "project", "", "Filter by project name")

	return cmd
}

// Update command
func NewUpdateCmd(tm *Manager) *cobra.Command {
	var title, description, status, priority, project string

	cmd := &cobra.Command{
		Use:   "update [id]",
		Short: "Update a task",
		Long: "Update task properties like title, description, status, priority, or project",
		Args: cobra.ExactArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			id := args[0]
			
			task, err := tm.storage.GetTask(id)
			if err != nil {
				fmt.Fprintf(os.Stderr, "Task not found: %v\n", err)
				return
			}

			// Update fields if provided
			if title != "" {
				task.Title = title
			}
			if description != "" {
				task.Description = description
			}
			if status != "" {
				task.Status = status
			}
			if priority != "" {
				task.Priority = priority
			}
			if project != "" {
				task.Project = project
			}
			task.UpdatedAt = time.Now()

			if err := tm.storage.UpdateTask(id, task); err != nil {
				fmt.Fprintf(os.Stderr, "Failed to update task: %v\n", err)
				return
			}

			fmt.Printf("✓ Updated task: %s\n", task.Title)
		},
	}

	cmd.Flags().StringVar(&title, "title", "", "New title")
	cmd.Flags().StringVar(&description, "desc", "", "New description")
	cmd.Flags().StringVar(&status, "status", "", "New status (pending, in-progress, completed)")
	cmd.Flags().StringVar(&priority, "priority", "", "New priority (low, medium, high)")
	cmd.Flags().StringVar(&project, "project", "", "New project name")

	return cmd
}

// Delete command
func NewDeleteCmd(tm *Manager) *cobra.Command {
	cmd := &cobra.Command{
		Use:   "delete [id]",
		Short: "Delete a task",
		Long: "Remove a task by its ID",
		Args: cobra.ExactArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			id := args[0]
			
			task, err := tm.storage.GetTask(id)
			if err != nil {
				fmt.Fprintf(os.Stderr, "Task not found: %v\n", err)
				return
			}

			if err := tm.storage.DeleteTask(id); err != nil {
				fmt.Fprintf(os.Stderr, "Failed to delete task: %v\n", err)
				return
			}

			fmt.Printf("✓ Deleted task: %s\n", task.Title)
		},
	}

	return cmd
}

// Search command
func NewSearchCmd(tm *Manager) *cobra.Command {
	cmd := &cobra.Command{
		Use:   "search [query]",
		Short: "Search tasks",
		Long: "Search tasks by title or description",
		Args: cobra.ExactArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			query := args[0]
			
			tasks, err := tm.storage.SearchTasks(query)
			if err != nil {
				fmt.Fprintf(os.Stderr, "Failed to search tasks: %v\n", err)
				return
			}

			if len(tasks) == 0 {
				fmt.Printf("No tasks found for: %s\n", query)
				return
			}

			fmt.Printf("Found %d tasks for: %s\n\n", len(tasks), query)
			for _, task := range tasks {
				statusIcon := getStatusIcon(task.Status)
				priorityIcon := getPriorityIcon(task.Priority)
				fmt.Printf("%s %s - %s [%s]\n", statusIcon, priorityIcon, task.Title, task.Project)
				fmt.Printf("   ID: %s\n\n", task.ID)
			}
		},
	}

	return cmd
}

// Complete command
func NewCompleteCmd(tm *Manager) *cobra.Command {
	cmd := &cobra.Command{
		Use:   "complete [id]",
		Short: "Mark task as completed",
		Long: "Mark a task as completed and update its status",
		Args: cobra.ExactArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			id := args[0]
			
			task, err := tm.storage.GetTask(id)
			if err != nil {
				fmt.Fprintf(os.Stderr, "Task not found: %v\n", err)
				return
			}

			task.Status = "completed"
			task.UpdatedAt = time.Now()

			if err := tm.storage.UpdateTask(id, task); err != nil {
				fmt.Fprintf(os.Stderr, "Failed to complete task: %v\n", err)
				return
			}

			fmt.Printf("✓ Completed task: %s\n", task.Title)
		},
	}

	return cmd
}

func getStatusIcon(status string) string {
	switch status {
	case "completed":
		return "✅"
	case "in-progress":
		return "🔄"
	case "pending":
		return "⏳"
	default:
		return "❓"
	}
}

func getPriorityIcon(priority string) string {
	switch priority {
	case "high":
		return "🔴"
	case "medium":
		return "🟡"
	case "low":
		return "🟢"
	default:
		return "⚪"
	}
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "task", "commands.go"), []byte(commandsGo), 0644); err != nil {
