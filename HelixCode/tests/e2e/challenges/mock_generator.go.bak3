func TestTaskValidation(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := filepath.Join(tmpDir, "validation.db")
	
	store, err := storage.NewStorage(dbPath)
	if err != nil {
		t.Fatal(err)
	}
	defer store.Close()

	// Test creating task with various statuses and priorities
	validStatuses := []string{"pending", "in-progress", "completed"}
	validPriorities := []string{"low", "medium", "high"}

	for i, status := range validStatuses {
		for j, priority := range validPriorities {
			task := &storage.Task{
				ID:          fmt.Sprintf("task-%d-%d", i, j),
				Title:       fmt.Sprintf("Test %s %s", status, priority),
				Description: "Test task",
				Status:      status,
				Priority:    priority,
				Project:     "test",
				CreatedAt:   time.Now(),
				UpdatedAt:   time.Now(),
			}

			err := store.AddTask(task)
			if err != nil {
				t.Errorf("Failed to add task with status '%s' and priority '%s': %v", status, priority, err)
			}
		}
	}

	// Verify all tasks were added
	allTasks, err := store.ListTasks()
	if err != nil {
		t.Errorf("Failed to list tasks: %v", err)
	}
	expectedCount := len(validStatuses) * len(validPriorities)
	if len(allTasks) != expectedCount {
		t.Errorf("Expected %d tasks, got %d", expectedCount, len(allTasks))
	}
}

func TestConcurrentOperations(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := filepath.Join(tmpDir, "concurrent.db")
	
	store, err := storage.NewStorage(dbPath)
	if err != nil {
		t.Fatal(err)
	}
	defer store.Close()

	// Test concurrent access
	done := make(chan bool, 10)
	for i := 0; i < 10; i++ {
		go func(id int) {
			task := &storage.Task{
				ID:          fmt.Sprintf("concurrent-%d", id),
				Title:       fmt.Sprintf("Concurrent Task %d", id),
				Description: "Test concurrent operation",
				Status:      "pending",
				Priority:    "medium",
				Project:     "test",
				CreatedAt:   time.Now(),
				UpdatedAt:   time.Now(),
			}
			err := store.AddTask(task)
			if err != nil {
				t.Errorf("Failed to add concurrent task %d: %v", id, err)
			}
			done <- true
		}(i)
	}

	// Wait for all goroutines to complete
	for i := 0; i < 10; i++ {
		<-done
	}

	// Verify all tasks were added
	tasks, err := store.ListTasks()
	if err != nil {
		t.Errorf("Failed to list tasks: %v", err)
	}
	if len(tasks) != 10 {
		t.Errorf("Expected 10 tasks, got %d", len(tasks))
	}
}
`
