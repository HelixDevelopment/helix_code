// GenerateJSONValidatorCLI generates a mock JSON Validator CLI tool
func (g *MockGenerator) GenerateJSONValidatorCLI(ctx context.Context, outputDir string) error {
	// Create directory structure
	dirs := []string{
		filepath.Join(outputDir, "validator"),
		filepath.Join(outputDir, "tests"),
	}

	for _, dir := range dirs {
		if err := os.MkdirAll(dir, 0755); err != nil {
			return fmt.Errorf("failed to create directory %s: %w", dir, err)
		}
	}

	// Create go.mod
	goMod := `module json-validator-cli

go 1.24

require (
	github.com/spf13/cobra v1.8.0
	github.com/itchyny/gojq v0.12.16
)

require (
	github.com/inconshreveable/mousetrap v1.1.0 // indirect
	github.com/spf13/pflag v1.0.5 // indirect
)
`
	if err := os.WriteFile(filepath.Join(outputDir, "go.mod"), []byte(goMod), 0644); err != nil {
		return err
	}

	// Create main.go
	mainGo := `package main

import (
	"fmt"
	"os"
	"json-validator-cli/validator"

	"github.com/spf13/cobra"
)

var (
	schemaFile string
	verbose   bool
)

func main() {
	var rootCmd = &cobra.Command{
		Use:   "json-validator",
		Short: "A fast and flexible JSON validation tool",
		Long: ` + "`" + `JSON Validator CLI

A powerful command-line tool for validating JSON files against JSON schemas.
Supports multiple output formats and validation modes.` + "`" + `,
		Args: cobra.MinimumNArgs(1),
		Run: func(cmd *cobra.Command, args []string) {
			if schemaFile == "" {
				fmt.Fprintln(os.Stderr, "Error: --schema is required")
				os.Exit(1)
			}

			for _, file := range args {
				result, err := validator.ValidateJSON(file, schemaFile, verbose)
				if err != nil {
					fmt.Fprintf(os.Stderr, "Error validating %s: %v\n", file, err)
					continue
				}

				if result.Valid {
					fmt.Printf("✓ %s is valid\n", file)
				} else {
					fmt.Printf("✗ %s is invalid\n", file)
					for _, e := range result.Errors {
						fmt.Printf("  - %s\n", e)
					}
				}
			}
		},
	}

	rootCmd.Flags().StringVarP(&schemaFile, "schema", "s", "", "JSON schema file to validate against")
	rootCmd.Flags().BoolVarP(&verbose, "verbose", "v", false, "Verbose output")

	if err := rootCmd.Execute(); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "main.go"), []byte(mainGo), 0644); err != nil {
		return err
	}

	// Create validator/validator.go
	validatorGo := `package validator

import (
	"bytes"
	"encoding/json"
	"fmt"
	"io"
	"os"

	"github.com/itchyny/gojq"
)

type ValidationResult struct {
	Valid  bool
	Errors []string
}

func ValidateJSON(filename, schemaFile string, verbose bool) (*ValidationResult, error) {
	// Read JSON file
	jsonData, err := os.ReadFile(filename)
	if err != nil {
		return nil, fmt.Errorf("failed to read JSON file: %w", err)
	}

	// Parse JSON
	var data interface{}
	if err := json.Unmarshal(jsonData, &data); err != nil {
		return nil, fmt.Errorf("failed to parse JSON: %w", err)
	}

	// Read schema if provided
	if schemaFile != "" {
		schemaData, err := os.ReadFile(schemaFile)
		if err != nil {
			return nil, fmt.Errorf("failed to read schema file: %w", err)
		}

		// Parse and validate against schema
		result, err := validateAgainstSchema(jsonData, schemaData)
		if err != nil {
			return nil, fmt.Errorf("schema validation failed: %w", err)
		}
		return result, nil
	}

	// Basic JSON syntax validation
	return &ValidationResult{Valid: true, Errors: []string{}}, nil
}

func validateAgainstSchema(jsonData, schemaData []byte) (*ValidationResult, error) {
	// Parse schema
	var schema interface{}
	if err := json.Unmarshal(schemaData, &schema); err != nil {
		return nil, fmt.Errorf("failed to parse schema: %w", err)
	}

	// Parse JSON data
	var data interface{}
	if err := json.Unmarshal(jsonData, &data); err != nil {
		return nil, fmt.Errorf("failed to parse JSON data: %w", err)
	}

	// Use gojq for JSON schema validation
	query, err := gojq.Parse(". | with_entries(select(.value != null))")
	if err != nil {
		return nil, fmt.Errorf("failed to create validation query: %w", err)
	}

	input := map[string]interface{}{"data": data, "schema": schema}
	iter := query.Run(input)

	var result ValidationResult
	result.Valid = true

	for {
		v, ok := iter.Next()
		if !ok {
			break
		}
		if err, ok := v.(error); ok {
			result.Valid = false
			result.Errors = append(result.Errors, err.Error())
		}
	}

	return &result, nil
}

func PrettyPrintJSON(data interface{}) (string, error) {
	buffer := &bytes.Buffer{}
	encoder := json.NewEncoder(buffer)
	encoder.SetIndent("", "  ")
	if err := encoder.Encode(data); err != nil {
		return "", err
	}
	return buffer.String(), nil
}

func ReadJSONFromFile(filename string) (interface{}, error) {
	file, err := os.Open(filename)
	if err != nil {
		return nil, err
	}
	defer file.Close()

	data, err := io.ReadAll(file)
	if err != nil {
		return nil, err
	}

	var result interface{}
	if err := json.Unmarshal(data, &result); err != nil {
		return nil, err
	}

	return result, nil
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "validator", "validator.go"), []byte(validatorGo), 0644); err != nil {
		return err
	}

	// Create tests/validator_test.go
	testGo := `package tests

import (
	"json-validator-cli/validator"
	"os"
	"path/filepath"
	"strings"
	"testing"
)

func TestValidJSON(t *testing.T) {
	// Create a temporary valid JSON file
	tmpDir := t.TempDir()
	validJSON := ` + "`" + `{
		"name": "test",
		"age": 25,
		"active": true
	}` + "`" + `
	validFile := filepath.Join(tmpDir, "valid.json")
	if err := os.WriteFile(validFile, []byte(validJSON), 0644); err != nil {
		t.Fatal(err)
	}

	result, err := validator.ValidateJSON(validFile, "", false)
	if err != nil {
		t.Errorf("Expected no error, got %v", err)
	}
	if !result.Valid {
		t.Error("Expected JSON to be valid")
	}
}

func TestInvalidJSON(t *testing.T) {
	// Create a temporary invalid JSON file
	tmpDir := t.TempDir()
	invalidJSON := ` + "`" + `{
		"name": "test",
		"age": 25,
		"active":
	}` + "`" + `
	invalidFile := filepath.Join(tmpDir, "invalid.json")
	if err := os.WriteFile(invalidFile, []byte(invalidJSON), 0644); err != nil {
		t.Fatal(err)
	}

	_, err := validator.ValidateJSON(invalidFile, "", false)
	if err == nil {
		t.Error("Expected error for invalid JSON")
	}
}

func TestSchemaValidation(t *testing.T) {
	// Create schema
	tmpDir := t.TempDir()
	schema := ` + "`" + `{
		"type": "object",
		"properties": {
			"name": {"type": "string"},
			"age": {"type": "number"}
		},
		"required": ["name", "age"]
	}` + "`" + `
	schemaFile := filepath.Join(tmpDir, "schema.json")
	if err := os.WriteFile(schemaFile, []byte(schema), 0644); err != nil {
		t.Fatal(err)
	}

	// Valid JSON against schema
	validJSON := ` + "`" + `{
		"name": "test",
		"age": 25
	}` + "`" + `
	validFile := filepath.Join(tmpDir, "valid.json")
	if err := os.WriteFile(validFile, []byte(validJSON), 0644); err != nil {
		t.Fatal(err)
	}

	result, err := validator.ValidateJSON(validFile, schemaFile, false)
	if err != nil {
		t.Errorf("Expected no error, got %v", err)
	}
	if !result.Valid {
		t.Error("Expected JSON to be valid against schema")
	}
}

func TestSchemaValidationFail(t *testing.T) {
	// Create schema
	tmpDir := t.TempDir()
	schema := ` + "`" + `{
		"type": "object",
		"properties": {
			"name": {"type": "string"},
			"age": {"type": "number"}
		},
		"required": ["name", "age"]
	}` + "`" + `
	schemaFile := filepath.Join(tmpDir, "schema.json")
	if err := os.WriteFile(schemaFile, []byte(schema), 0644); err != nil {
		t.Fatal(err)
	}

	// Invalid JSON against schema
	invalidJSON := ` + "`" + `{
		"name": "test"
	}` + "`" + `
	invalidFile := filepath.Join(tmpDir, "invalid.json")
	if err := os.WriteFile(invalidFile, []byte(invalidJSON), 0644); err != nil {
		t.Fatal(err)
	}

	result, err := validator.ValidateJSON(invalidFile, schemaFile, false)
	if err != nil {
		t.Errorf("Expected no error, got %v", err)
	}
	if result.Valid {
		t.Error("Expected JSON to be invalid against schema")
	}
}

func TestPrettyPrintJSON(t *testing.T) {
	data := map[string]interface{}{
		"name": "test",
		"items": []string{"a", "b", "c"},
	}

	result, err := validator.PrettyPrintJSON(data)
	if err != nil {
		t.Errorf("Expected no error, got %v", err)
	}
	if !strings.Contains(result, "name") {
		t.Error("Expected name in result")
	}
}
`
	if err := os.WriteFile(filepath.Join(outputDir, "tests", "validator_test.go"), []byte(testGo), 0644); err != nil {
		return err
