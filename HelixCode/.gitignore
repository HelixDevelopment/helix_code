# Worktrees created by HelixCode P1-F04 EnterWorktree (do NOT commit)
.helix-worktrees/

# === Runtime test artefacts (regenerated by tests; do NOT commit) ===
# Built binaries placed at the inner-module root by `go build ./cmd/<name>/`
# or by application targets (terminal-ui, desktop, etc.)
/infrastructure
/helixcode
/cli
/server
/terminal-ui
/desktop
/config-test
/security-test
/security-fix
/performance-optimization
/helix-config
# Runtime audit / autonomy state directories created by test runs
internal/**/.helix/
internal/**/.helixcode/
# Performance optimisation auto-regenerated reports
internal/performance/reports/
# === END runtime test artefacts ===
