#!/usr/bin/env bash
# scripts/git-hooks/pre-push
# Phase 0 P0-09 — force-push protection per CONST-042.
#
# Reject --force / -f / --force-with-lease pushes unless
# HELIX_FORCE_PUSH_APPROVED=1 is set in the calling environment.
#
# This is a COURTESY GATE; the constitutional clause (CONST-042) is the
# actual contract.  On platforms where /proc/PPID/cmdline is unavailable
# (e.g. macOS, BSDs) the hook degrades gracefully: it warns and exits 0
# rather than blocking every push.
#
# Additionally, runs scripts/scan-secrets.sh --range <base> <new> — scoped
# to the COMMITS ACTUALLY BEING PUSHED — as a final pre-push gate. This was
# a whole-working-tree scan (`scan-secrets.sh` with no args) until the
# 2026-07-11 fix below; the whole-tree form also swept UNTRACKED files
# (scratchpad reports, local notes) sitting in the working directory and
# blocked unrelated pushes on their content (see docs/audit/bypass_events.md
# 2026-07-11 entry — "Follow-up: ... scope pre-push to pushed-commits not
# full working tree."). §11.4.6: a push should be judged on what it actually
# publishes, not on whatever happens to be lying around locally.
#
# The pushed range is read from the ref-update lines git supplies on this
# hook's STDIN (documented pre-push protocol: one line per ref being
# updated, "<local-ref> SP <local-oid> SP <remote-ref> SP <remote-oid>
# LF"). For each updated ref: if the remote already has the ref, the range
# is remote-oid..local-oid (the primary, everyday "update an existing
# branch" case — diffs ONLY the new commits). If the ref is brand-new on
# the remote (remote-oid is the all-zero SHA), the base is resolved as the
# best-known merge-base against any existing remote-tracking ref for THIS
# remote (content already known to be there); if none is found (a genuine
# first-ever push with no shared history), the base falls back to the
# well-known git empty-tree object so the ENTIRE new branch is scanned
# (correct, if potentially large — a rare edge case, not the common path).
#
# If the scanner is missing (early P0 bootstrap), the check is skipped
# with a warning rather than blocking the push.

set -uo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

# ---------------------------------------------------------------------------
# 1.  Force-push detection via /proc/<PPID>/cmdline
# ---------------------------------------------------------------------------
ppid_cmdline=""
if [ -r "/proc/$PPID/cmdline" ]; then
  ppid_cmdline=$(tr '\0' ' ' < "/proc/$PPID/cmdline")
fi

is_force=0
if [ -n "$ppid_cmdline" ]; then
  case "$ppid_cmdline" in
    *" --force "*|*" --force"|*" -f "*|*" -f"|*" --force-with-lease"*)
      is_force=1
      ;;
  esac
else
  # /proc not available (macOS / BSD).  Warn but do not block.
  echo "WARN: pre-push hook: /proc/$PPID/cmdline not readable." >&2
  echo "      Force-push detection is unavailable on this platform." >&2
  echo "      CONST-042 constitutional clause is still the contract." >&2
fi

if [ "$is_force" -eq 1 ] && [ "${HELIX_FORCE_PUSH_APPROVED:-0}" != "1" ]; then
  echo "" >&2
  echo "============================================================" >&2
  echo "BLOCKED by pre-push hook (CONST-042 No-Force-Push)" >&2
  echo "============================================================" >&2
  echo "Force push detected. Per CONST-042 (synthesis spec §2.4)," >&2
  echo "force pushes require explicit user approval per operation." >&2
  echo "" >&2
  echo "If approved by the user IN THIS CONVERSATION, run:" >&2
  echo "  HELIX_FORCE_PUSH_APPROVED=1 git push <args>" >&2
  echo "" >&2
  echo "Remote:          $remote_name $remote_url" >&2
  echo "Parent cmdline:  $ppid_cmdline" >&2
  echo "============================================================" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# 2.  Secret scan gate, SCOPED TO THE PUSHED RANGE (best-effort; missing
#     scanner does NOT block push during early P0 bootstrap).
# ---------------------------------------------------------------------------
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
SCANNER="$REPO_ROOT/scripts/scan-secrets.sh"
ZERO_SHA="0000000000000000000000000000000000000000"
EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"

if [ -x "$SCANNER" ]; then
  scan_block=0
  # STDIN carries the ref-update lines for this push (git's documented
  # pre-push protocol). Read them all before invoking any subcommand that
  # might itself touch fd0, to avoid interleaving reads on the same pipe.
  ref_updates=$(cat)

  while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_ref" ] && continue
    # Deleting a ref (local_sha all-zero) publishes nothing new — skip.
    [ "$local_sha" = "$ZERO_SHA" ] && continue

    base="$remote_sha"
    if [ "$remote_sha" = "$ZERO_SHA" ]; then
      # Brand-new ref on the remote: find the best-known base so we scan
      # only what's genuinely new to the remote, not the ref's entire
      # history. Only consider remote-tracking refs for THIS remote
      # (content already known to be published there); never local
      # branches (a candidate could trivially be the very branch being
      # pushed, self-matching to an empty, secret-hiding diff).
      base=""
      while IFS= read -r candidate; do
        [ -z "$candidate" ] && continue
        mb=$(git merge-base "$local_sha" "$candidate" 2>/dev/null) || continue
        if [ -n "$mb" ]; then
          base="$mb"
          break
        fi
      done < <(git for-each-ref --format='%(objectname)' "refs/remotes/${remote_name}/" 2>/dev/null)
      [ -z "$base" ] && base="$EMPTY_TREE"
    fi

    range_out=$("$SCANNER" --range "$base" "$local_sha" 2>&1)
    range_rc=$?
    if [ "$range_rc" -ne 0 ]; then
      echo "" >&2
      echo "============================================================" >&2
      echo "BLOCKED by pre-push hook: scan-secrets.sh --range found" >&2
      echo "credential pattern(s) in the commits being pushed ($local_ref)." >&2
      printf '%s\n' "$range_out" >&2
      echo "Run: scripts/scan-secrets.sh --range $base $local_sha" >&2
      echo "and remediate before pushing." >&2
      echo "============================================================" >&2
      scan_block=1
    fi
  done <<< "$ref_updates"

  if [ "$scan_block" -eq 1 ]; then
    exit 1
  fi
else
  echo "WARN: pre-push hook: $SCANNER not found or not executable." >&2
  echo "      Secret scan skipped (best-effort during bootstrap)." >&2
fi

exit 0
