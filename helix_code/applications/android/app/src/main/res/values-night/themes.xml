<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Night-qualified HelixCode brand theme. The brand is always dark, so the
      night variant mirrors the base brand palette exactly to guarantee a
      consistent dark experience regardless of system day/night state.
    -->
    <style name="Theme.HelixCode" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/helix_primary</item>
        <item name="colorPrimaryDark">@color/helix_primary_dim</item>
        <item name="colorPrimaryVariant">@color/helix_primary_dim</item>
        <item name="colorOnPrimary">@color/helix_bg_base</item>

        <item name="colorSecondary">@color/helix_secondary</item>
        <item name="colorSecondaryVariant">@color/helix_secondary</item>
        <item name="colorOnSecondary">@color/helix_bg_base</item>

        <item name="colorAccent">@color/helix_primary</item>

        <item name="android:colorBackground">@color/helix_bg_base</item>
        <item name="android:windowBackground">@color/helix_bg_base</item>
        <item name="colorSurface">@color/helix_bg_surface</item>
        <item name="colorOnBackground">@color/helix_fg_text</item>
        <item name="colorOnSurface">@color/helix_fg_text</item>
        <item name="android:textColorPrimary">@color/helix_fg_text</item>
        <item name="android:textColorSecondary">@color/helix_fg_muted</item>

        <item name="colorError">@color/helix_error</item>
        <item name="colorOnError">@color/helix_bg_base</item>

        <item name="android:statusBarColor">@color/helix_bg_base</item>
        <item name="android:navigationBarColor">@color/helix_bg_base</item>
    </style>
</resources>
