# Development tools
.goreleaser.yml
.dockerignore
# Dockerfile* was overly broad — it hid the build/Dockerfile.builder that
# the containerized build path relies on. Only ignore Dockerfiles at the
# very top of HelixCode/ (used historically for one-off prototypes);
# Dockerfiles in subdirs (docker/, applications/, tests/) MUST be tracked
# because they describe reproducible build/test environments.
/Dockerfile
/Dockerfile.*
# (subdirectory Dockerfiles, e.g. docker/build/Dockerfile.builder,
# applications/desktop/Dockerfile.* are intentionally NOT ignored.)

# Backup files
*.bak
*.backup

# Certificate files
*.pem
*.crt
*.key

# Mobile build artifacts
mobile/ios/build/
mobile/android/build/

# Gomobile generated frameworks
*.xcframework/
*.aar
mobile.aar

# Web build artifacts
web/frontend/dist/
web/frontend/node_modules/

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

