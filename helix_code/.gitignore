
# Binaries and build artifacts
bin/
dist/
# Anchor `build/` at the module root so it only ignores top-level Go build
# output (./build/) and NOT subdirectory paths like docker/build/ which
# contain version-controlled build infrastructure (Dockerfile.builder).
/build/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries
*.test

# Output of the go coverage tool
coverage.out
coverage.html

# §11.4.85 stress/chaos captured-evidence — regenerated by `go test` (CONST-053 build derivative)
qa-results/

