# HelixCode Full Test Environment Configuration
# This file provides all environment variables needed to run ALL tests
# with ZERO skipped tests using the docker-compose.full-test.yml infrastructure.
#
# Usage:
#   source .env.full-test
#   go test -v ./...

# ============================================
# DATABASE CONFIGURATION
# ============================================
HELIX_DATABASE_HOST=localhost
HELIX_DATABASE_PORT=5432
HELIX_DATABASE_USER=helixcode
HELIX_DATABASE_PASSWORD=helixcode_test_password
HELIX_DATABASE_NAME=helixcode_test
HELIX_DATABASE_ENABLED=true
HELIX_DATABASE_SSL_MODE=disable

# ============================================
# REDIS CONFIGURATION
# ============================================
HELIX_REDIS_HOST=localhost
HELIX_REDIS_PORT=6379
HELIX_REDIS_ENABLED=true
HELIX_REDIS_PASSWORD=

# ============================================
# AUTHENTICATION
# ============================================
HELIX_AUTH_JWT_SECRET=test-jwt-secret-for-testing-only-minimum-32-characters-long
HELIX_AUTH_TOKEN_EXPIRY=24h

# ============================================
# LOCAL LLM PROVIDERS
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2:7b

# ============================================
# MOCK LLM SERVER (For Cloud Provider Tests)
# ============================================
MOCK_LLM_ENDPOINT=http://localhost:8090

# Mock provider endpoints - all point to mock server
OPENAI_API_KEY=mock-openai-key-for-testing
OPENAI_API_BASE=http://localhost:8090/v1

ANTHROPIC_API_KEY=mock-anthropic-key-for-testing
ANTHROPIC_API_BASE=http://localhost:8090

GEMINI_API_KEY=mock-gemini-key-for-testing
GOOGLE_API_KEY=mock-gemini-key-for-testing
GEMINI_API_BASE=http://localhost:8090

AZURE_OPENAI_ENDPOINT=http://localhost:8090
AZURE_OPENAI_API_KEY=mock-azure-key-for-testing
AZURE_API_VERSION=2024-02-15-preview

GROQ_API_KEY=mock-groq-key-for-testing
GROQ_API_BASE=http://localhost:8090/openai/v1

MISTRAL_API_KEY=mock-mistral-key-for-testing
MISTRAL_API_BASE=http://localhost:8090/v1

COHERE_API_KEY=mock-cohere-key-for-testing
COHERE_API_BASE=http://localhost:8090/v1

# AWS/Bedrock (mock)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock-aws-access-key
AWS_SECRET_ACCESS_KEY=mock-aws-secret-key

# ============================================
# BROWSER TESTING
# ============================================
CHROME_DEBUGGER_URL=ws://localhost:9222
SELENIUM_URL=http://localhost:4444
CHROME_PATH=/usr/bin/chromium
HEADLESS_CHROME=true

# ============================================
# SSH WORKER TESTING
# ============================================
SSH_TEST_HOST=localhost
SSH_TEST_PORT=2222
SSH_TEST_USER=helixcode
SSH_TEST_PASSWORD=test_password
SSH_TEST_KEY_PATH=./tests/infrastructure/ssh_keys/id_rsa

# Additional workers
SSH_WORKER_1_HOST=localhost
SSH_WORKER_1_PORT=2223
SSH_WORKER_2_HOST=localhost
SSH_WORKER_2_PORT=2224
SSH_WORKER_3_HOST=localhost
SSH_WORKER_3_PORT=2225

# ============================================
# MEMORY/KNOWLEDGE PROVIDERS
# ============================================
COGNEE_ENDPOINT=http://localhost:8000
COGNEE_API_KEY=test_cognee_key_123

WEAVIATE_ENDPOINT=http://localhost:8081
WEAVIATE_API_KEY=

CHROMADB_ENDPOINT=http://localhost:8082
QDRANT_ENDPOINT=http://localhost:6333

# ============================================
# NOTIFICATION TESTING
# ============================================
MOCK_SLACK_ENDPOINT=http://localhost:8091
SLACK_WEBHOOK_URL=http://localhost:8091/services/test/webhook
SLACK_BOT_TOKEN=xoxb-mock-token-for-testing

# ============================================
# TEST BEHAVIOR
# ============================================
# Disable all test skipping
SKIP_EXPENSIVE_TESTS=false
SKIP_HARDWARE_TESTS=false
SKIP_INTEGRATION_TESTS=false
SKIP_BROWSER_TESTS=false
SKIP_SSH_TESTS=false
SKIP_LLM_TESTS=false

# Test configuration
TESTING_SHORT=false
CI_MODE=true
TEST_TIMEOUT=30m
PARALLEL_JOBS=4

# ============================================
# SERVER CONFIGURATION
# ============================================
HELIX_SERVER_PORT=8080
HELIX_SERVER_HOST=0.0.0.0

# ============================================
# LOGGING
# ============================================
HELIX_LOG_LEVEL=debug
HELIX_LOG_FORMAT=text

# ============================================
# AUDIO/VOICE (Virtual Device)
# ============================================
PULSE_SERVER=unix:/run/pulse/native
AUDIO_DEVICE=null

# ============================================
# COVERAGE
# ============================================
COVERAGE_THRESHOLD=85
COVERAGE_OUTPUT=coverage.out
